# Copy to `.env` and fill in real values.
# Docker Compose: env_file ./backend/.env
# Local `dotnet run`: loaded automatically by Program.cs

ConnectionStrings__DefaultConnection=Server=mysql;Port=3306;Database=camp_project;User=app;Password=CHANGE_ME;SslMode=Disabled;AllowPublicKeyRetrieval=True;ConnectionTimeout=60;

Jwt__SecretKey=CHANGE_ME_TO_A_LONG_RANDOM_SECRET_KEY_AT_LEAST_32_CHARS

# Public site URL (local Docker / AWS). Example AWS: http://44.194.248.98:8000
App__FrontendBaseUrl=http://localhost:8000

Cors__AllowedOrigins__0=http://localhost:8000
Cors__AllowedOrigins__1=http://127.0.0.1:8000
# Cors__AllowedOrigins__2=http://44.194.248.98:8000

Authentication__Google__ClientId=
Authentication__Google__ClientSecret=
Authentication__Facebook__AppId=
Authentication__Facebook__AppSecret=

Smtp__Host=smtp.gmail.com
Smtp__Port=587
Smtp__User=
Smtp__Password=
Smtp__From=

DefaultAttributes__SystemUserEmail=
DefaultAttributes__SystemUserPassword=

# Cloudinary — CloudName is Product Environment Credentials → Cloud name (not the upload preset).
Cloudinary__CloudName=hpkgdqze
Cloudinary__ApiKey=
Cloudinary__ApiSecret=
Cloudinary__AssetFolder=abza
Cloudinary__UploadPreset=ml_default
Cloudinary__MaxFileSizeBytes=10485760
